local function get_targets_in_fov(usefov, fov_size)
    local e_part, e_pos, t_part, t_pos = nil, nil, nil, nil
    local e_dist, t_dist = usefov and fov_size or math.huge, usefov and fov_size or math.huge
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    for _, character in pairs(validcharacters) do
        if not character or not character.Parent then continue end
        
        -- ИГНОРИРУЕМ МЕРТВЫХ ИГРОКОВ В АИМБОТЕ
        local humanoid = character:FindFirstChild("Humanoid") or character:FindFirstChildWhichIsA("Humanoid")
        if humanoid and humanoid.Health <= 0 then continue end

        local hitpart = character:FindFirstChild("LowerTorso") or character:FindFirstChild("HumanoidRootPart")
        if hitpart then
            local pos, onscreen = Camera:WorldToViewportPoint(hitpart.Position)
            local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
            if (usefov and onscreen or not usefov) and dist < (usefov and fov_size or math.huge) then
                local customName = assignedNames[character] or character.Name
                if team_feature_enabled and Teammates[customName] then
                    if dist < t_dist then t_part = hitpart; t_dist = dist; t_pos = Vector2.new(pos.X, pos.Y) end
                else
                    if dist < e_dist then e_part = hitpart; e_dist = dist; e_pos = Vector2.new(pos.X, pos.Y) end
                end
            end
        end
    end
    return e_part, e_pos, t_part, t_pos
end

