local function sendChatMessage(text)
    pcall(function()
        game:GetService("Players"):Chat(text)
    end)
end

local function handleIncomingMessage(sender, text)
    if systemMessages[text] and sender ~= "Система" then return end

    local msgId = sender .. "_" .. text
    if recentMessages[msgId] then return end
    recentMessages[msgId] = true
    task.delay(0.5, function() recentMessages[msgId] = nil end)

    addChatMessage(sender, text, sender == "Система")
    if not ChatGui.Enabled then
        newMessagesCount = newMessagesCount + 1
    end
end

InputBox.FocusLost:Connect(function(enterPressed)
    if enterPressed and InputBox.Text ~= "" then
        local msg = InputBox.Text
        InputBox.Text = ""
        sendChatMessage(msg)
        handleIncomingMessage(LocalPlayer.Name, msg)
    end
end)

for _, p in pairs(Players:GetPlayers()) do
