local activeBags, activeCrates, MAX_RENDER_DISTANCE = {}, {}, 1200
local ChamStorage = guiParent:FindFirstChild("TridentVisuals") or Instance.new("Folder", guiParent)
ChamStorage.Name = "TridentVisuals"

local function createDrawings()
    return {
        box = cheat.utility.new_drawing("Square", { Filled = false, Thickness = 1, Visible = false }),
        name = cheat.utility.new_drawing("Text", { Center = true, Visible = false, Size = 13, Outline = true, Font = 2 }),
        dist = cheat.utility.new_drawing("Text", { Center = true, Visible = false, Size = 11, Outline = true, Font = 2 })
    }
end

local function applyWorldESP(model)
    if typeof(model) ~= "Instance" or not model:IsA("Model") then return end

    if model.Name == "Model" and #model:GetChildren() == 2 and model:FindFirstChild("Part") then
        local p1 = model:FindFirstChild("Part")
        if p1:IsA("BasePart") and p1.Size.Y < 3 and p1.Size.X < 3 and p1.Size.Z < 3 then
            local id = "Bag_" .. model:GetDebugId()
            local hl = ChamStorage:FindFirstChild(id) or Instance.new("Highlight", ChamStorage)
            hl.Name = id; hl.Adornee = model; hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            activeBags[model] = { highlight = hl, drawings = createDrawings(), part = p1, name = "мешок" }
        end
    end
    
    if not model.Name:find("InteriorContainer") and not model:FindFirstChild("State") then
        local children = {}
        for _, child in pairs(model:GetChildren()) do children[child.Name] = true end
        local isCrate, memeName = false, ""

        if children['Bottom'] and children['Top'] then isCrate = true; memeName = "йощек абични"
        elseif children['box'] and children['trash'] then isCrate = true; memeName = "мусор"
        elseif children['Dispenser'] and children['Machine'] then isCrate = true; memeName = "автомат с хилкай"
        elseif children['Body'] and children['Wheel'] then isCrate = true; memeName = "телега с лутом"
        elseif model.Name == "CashRegister" or model.Name == "Register" then isCrate = true; memeName = "каса"
        elseif model.Name == "Safe" then isCrate = true; memeName = "сейф ебать" end

        if model:FindFirstChild("Humanoid") then isCrate = false end

        if isCrate then
            local id = "Crate_" .. model:GetDebugId()
            local hl = ChamStorage:FindFirstChild(id) or Instance.new("Highlight", ChamStorage)
            hl.Name = id; hl.Adornee = model; hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            activeCrates[model] = { highlight = hl, drawings = createDrawings(), part = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart"), name = memeName }
        end
    end
end

for _, obj in ipairs(workspace:GetDescendants()) do applyWorldESP(obj) end
workspace.DescendantAdded:Connect(function(desc) task.wait(0.1); applyWorldESP(desc) end)
workspace.DescendantRemoving:Connect(function(obj)
    if activeBags[obj] then activeBags[obj].highlight:Destroy(); for _, d in pairs(activeBags[obj].drawings) do d:Remove() end; activeBags[obj] = nil end
    if activeCrates[obj] then activeCrates[obj].highlight:Destroy(); for _, d in pairs(activeCrates[obj].drawings) do d:Remove() end; activeCrates[obj] = nil end
end)

local rainbowHueWorld = 0
RunService.RenderStepped:Connect(function(dt)
    rainbowHueWorld = (rainbowHueWorld + dt * 0.2) % 1
    local rainbowColor = Color3.fromHSV(rainbowHueWorld, 1, 1)

    for model, data in pairs(activeBags) do
        if not model or not model.Parent or not data.part or not data.part.Parent then continue end
        local dist = (Camera.CFrame.Position - data.part.Position).Magnitude
        local inRange = dist <= MAX_RENDER_DISTANCE
        local pos, onScreen = Camera:WorldToViewportPoint(data.part.Position)
        local color = (Toggles.bags_rainbow.Value) and rainbowColor or Options.bags_color.Value

        if Toggles.bags_en.Value and inRange then
            data.highlight.Enabled = true; data.highlight.FillColor = color; data.highlight.OutlineColor = color
            data.highlight.FillTransparency = 1 - (Options.bags_trans.Value / 100); data.highlight.OutlineTransparency = 1 - (Options.bags_trans.Value / 100)
        else data.highlight.Enabled = false end

        if onScreen and inRange and (Toggles.bags_box.Value or Toggles.bags_name.Value or Toggles.bags_dist.Value) then
            data.drawings.box.Visible = Toggles.bags_box.Value
            data.drawings.box.Size = Vector2.new(1500 / pos.Z, 1500 / pos.Z)
            data.drawings.box.Position = Vector2.new(pos.X - data.drawings.box.Size.X / 2, pos.Y - data.drawings.box.Size.Y / 2)
            data.drawings.box.Color = color

            data.drawings.name.Visible = Toggles.bags_name.Value
            data.drawings.name.Text = data.name
            data.drawings.name.Position = data.drawings.box.Position - Vector2.new(0, 15)
            data.drawings.name.Color = color

            data.drawings.dist.Visible = Toggles.bags_dist.Value
            data.drawings.dist.Text = math.floor(dist) .. "m"
            data.drawings.dist.Position = data.drawings.box.Position + Vector2.new(data.drawings.box.Size.X / 2, data.drawings.box.Size.Y + 2)
            data.drawings.dist.Color = color
        else
            for _, d in pairs(data.drawings) do d.Visible = false end
        end
    end
    
    for model, data in pairs(activeCrates) do
        if not model or not model.Parent or not data.part or not data.part.Parent then continue end
        local dist = (Camera.CFrame.Position - data.part.Position).Magnitude
        local inRange = dist <= MAX_RENDER_DISTANCE
        local pos, onScreen = Camera:WorldToViewportPoint(data.part.Position)
        local color = (Toggles.crates_rainbow.Value) and rainbowColor or Options.crates_color.Value

        if Toggles.crates_en.Value and inRange then
            data.highlight.Enabled = true; data.highlight.FillColor = color; data.highlight.OutlineColor = color
            data.highlight.FillTransparency = 1 - (Options.crates_trans.Value / 100); data.highlight.OutlineTransparency = 1 - (Options.crates_trans.Value / 100)
        else data.highlight.Enabled = false end

        if onScreen and inRange and (Toggles.crates_box.Value or Toggles.crates_name.Value or Toggles.crates_dist.Value) then
            data.drawings.box.Visible = Toggles.crates_box.Value
            data.drawings.box.Size = Vector2.new(2500 / pos.Z, 2500 / pos.Z)
            data.drawings.box.Position = Vector2.new(pos.X - data.drawings.box.Size.X / 2, pos.Y - data.drawings.box.Size.Y / 2)
            data.drawings.box.Color = color

            data.drawings.name.Visible = Toggles.crates_name.Value
            data.drawings.name.Text = data.name
            data.drawings.name.Position = data.drawings.box.Position - Vector2.new(0, 15)
            data.drawings.name.Color = color

            data.drawings.dist.Visible = Toggles.crates_dist.Value
            data.drawings.dist.Text = math.floor(dist) .. "m"
            data.drawings.dist.Position = data.drawings.box.Position + Vector2.new(data.drawings.box.Size.X / 2, data.drawings.box.Size.Y + 2)
            data.drawings.dist.Color = color
        else
            for _, d in pairs(data.drawings) do d.Visible = false end
        end
    end
end)
