local function addtovc(obj)
    if not obj then return end
    if not obj:FindFirstChild("Head") and not obj:FindFirstChild("HumanoidRootPart") and not obj:FindFirstChild("LowerTorso") then return end
    validcharacters[obj] = obj
    if not assignedNames[obj] then
        local currentId = nameCounter
        nameCounter = nameCounter + 1
        assignedNames[obj] = "Loading " .. tostring(currentId)
        task.spawn(function()
            task.wait(0.5)
            if not obj or not obj.Parent then return end
            assignedNames[obj] = "Player " .. tostring(currentId)
        end)
    end
end

local function removefromvc(obj)
    if not validcharacters[obj] then return end
    validcharacters[obj] = nil
    assignedNames[obj] = nil
end

